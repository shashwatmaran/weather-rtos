{
  "id": null,
  "uid": "weather-rtos-writer",
  "title": "Weather RTOS - Writer Metrics",
  "panels": [
    {
      "type": "graph",
      "title": "Messages Processed",
      "datasource": "Prometheus",
      "targets": [
        { "expr": "weather_messages_processed", "legendFormat": "messages" }
      ],
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "graph",
      "title": "Queue Depth",
      "datasource": "Prometheus",
      "targets": [
        { "expr": "weather_queue_depth", "legendFormat": "depth" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "type": "graph",
      "title": "Backpressure Events",
      "datasource": "Prometheus",
      "targets": [
        { "expr": "weather_backpressure_events", "legendFormat": "backpressure" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    },
    {
      "type": "graph",
      "title": "Avg Ingestion Latency (ms)",
      "datasource": "Prometheus",
      "targets": [
        { "expr": "weather_ingestion_latency_avg_ms", "legendFormat": "latency" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 }
    },
    {
      "type": "graph",
      "title": "Throughput (msgs/sec)",
      "datasource": "Prometheus",
      "targets": [
        { "expr": "rate(weather_messages_processed[1m])", "legendFormat": "throughput" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 }
    }
  ],
  "schemaVersion": 16,
  "version": 1
}
