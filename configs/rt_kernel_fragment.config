# Linux Kernel RT Optimization Fragment
# Target: Linux 6.1+ with PREEMPT_RT

# Real-time Preemption
CONFIG_PREEMPT_RT=y
CONFIG_EXPERT=y

# Memory Optimizations
CONFIG_HUGETLBFS=y
CONFIG_HUGETLB_PAGE=y
CONFIG_CMA=y
CONFIG_DMA_CMA=y
CONFIG_CMA_SIZE_MBYTES=512

# CPU Isolation and Scheduling
CONFIG_NO_HZ_FULL=y
CONFIG_RCU_NOCB_CPU=y
CONFIG_CPUSETS=y
CONFIG_CGROUP_SCHED=y

# I/O Performance
CONFIG_IO_URING=y
